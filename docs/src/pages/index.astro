---
import Layout from "~/layouts/Layout.astro";
import resultsRaw from "~/data/results.json";

interface Row {
  model: string;
  base: string;
  train: string;
  benchmark: string;
  metric: string;
  value: number;
}
const results = resultsRaw as Row[];

// Pivot for the table: per-(base,train) rows × benchmark columns
const benchmarkOrder = [
  "wikitq_test",
  "fetaqa_test",
  "tabfact_test",
  "tabmwp_test",
  "totto_test",
  "infotabs_test",
  "tatqa_test",
  "hitab_test",
  "tablebench_test",
  "tablellm_wtq",
  "tablellm_fetaqa",
  "tablellm_tatqa",
  "tablellm_ottqa",
  "Beer_test",
  "DeepM_test",
  "Efthymiou_test",
  "Spreadsheets_CF_test",
  "Spreadsheets_DI_test",
  "Spreadsheets_ED_Real_test",
  "Spreadsheets_MVI_ColumnNoSep_test",
  "instruction_following_test",
];

const baseOrder = ["mistral-v0.3", "olmo", "phi-3", "phi-3-mini"];
const trainOrder = ["tablellama", "tablellm", "tablebench", "tablegpt", "tablegpt-small"];
const baseDisplay: Record<string, string> = {
  "mistral-v0.3": "Mistral-v0.3 (7B)",
  olmo: "OLMo (7B)",
  "phi-3": "Phi-3 (7B)",
  "phi-3-mini": "Phi-3-mini (4B)",
};
const trainDisplay: Record<string, string> = {
  tablellama: "TableLlama",
  tablellm: "TableLLM",
  tablebench: "TableBench",
  tablegpt: "TableGPT",
  "tablegpt-small": "TableGPT-small",
};

// Build a lookup table for fast cell access
type Cell = { value: number; metric: string };
const cells = new Map<string, Cell>();
for (const r of results) {
  cells.set(`${r.model}|${r.benchmark}`, { value: r.value, metric: r.metric });
}

// Combinations that have at least one result row
const combos: Array<{ base: string; train: string; model: string }> = [];
for (const base of baseOrder) {
  for (const train of trainOrder) {
    const model = `${base}-${train}`;
    if (results.some((r) => r.model === model)) {
      combos.push({ base, train, model });
    }
  }
}

const title = "What Really Matters for Table LLMs?";
const subtitle = "A Meta-Evaluation of Model and Data Effects";
const venue = "Findings of EACL 2026";

const authors = [
  { name: "Naihao Deng", aff: "1", email: "dnaihao@umich.edu", note: "*" },
  { name: "Sheng Zhang", aff: "2" },
  { name: "Henghui Zhu", aff: "3" },
  { name: "Shuaichen Chang", aff: "2" },
  { name: "Jiani Zhang", aff: "5" },
  { name: "Alexander Hanbo Li", aff: "4" },
  { name: "Chung-Wei Hang", aff: "2" },
  { name: "Hideo Kobayashi", aff: "2" },
  { name: "Yiqun Hu", aff: "2" },
  { name: "Patrick Ng", aff: "2" },
];

const affs: Record<string, string> = {
  "1": "University of Michigan",
  "2": "AWS AI Labs",
  "3": "Figma",
  "4": "OKX",
  "5": "Google",
};

const links = [
  { label: "📄 Paper (Anthology)", href: "https://aclanthology.org/2026.findings-eacl.195/", primary: true },
  { label: "💻 Code (GitHub)", href: "https://github.com/dnaihao/table-sft-eacl-2026" },
  { label: "🤗 Models (HF)", href: "https://huggingface.co/collections/dnaihao/table-llms" },
  { label: "💾 Predictions dataset", href: "https://huggingface.co/datasets/dnaihao/table-sft-eval-predictions" },
];

const bibtex = `@inproceedings{deng-etal-2026-really,
    title = "What Really Matters for Table {LLM}s? A Meta-Evaluation of Model and Data Effects",
    author = "Deng, Naihao  and Zhang, Sheng  and Zhu, Henghui  and Chang, Shuaichen  and Zhang, Jiani  and Li, Alexander Hanbo  and Hang, Chung-Wei  and Kobayashi, Hideo  and Hu, Yiqun  and Ng, Patrick",
    booktitle = "Findings of the Association for Computational Linguistics: EACL 2026",
    year = "2026",
    publisher = "Association for Computational Linguistics",
    url = "https://aclanthology.org/2026.findings-eacl.195/",
    doi = "10.18653/v1/2026.findings-eacl.195"
}`;
---

<Layout title={`${title} — ${venue}`}>
  <main class="mx-auto max-w-4xl px-6 py-16">
    <!-- Venue badge -->
    <div class="mb-6 flex justify-center">
      <span class="rounded-full bg-amber-100 px-4 py-1 text-sm font-medium uppercase tracking-wider text-amber-900">
        {venue}
      </span>
    </div>

    <!-- Title -->
    <h1 class="text-center text-4xl font-bold leading-tight text-stone-900 md:text-5xl">
      {title}
    </h1>
    <p class="mt-3 text-center text-xl text-stone-600 md:text-2xl">{subtitle}</p>

    <!-- Authors -->
    <div class="mx-auto mt-8 max-w-3xl text-center text-stone-700">
      <p class="leading-relaxed">
        {authors.map((a, i) => (
          <span>
            {a.name}
            <sup class="ml-0.5 text-xs text-stone-500">{a.aff}{a.note ?? ""}</sup>
            {i < authors.length - 1 ? <span>, </span> : null}
          </span>
        ))}
      </p>
      <p class="mt-2 text-sm text-stone-500">
        {Object.entries(affs).map(([k, v], i, arr) => (
          <span><sup class="text-xs">{k}</sup>{v}{i < arr.length - 1 ? <span> &nbsp;·&nbsp; </span> : null}</span>
        ))}
      </p>
      <p class="mt-1 text-xs text-stone-400">* Work done during Naihao's internship at AWS</p>
    </div>

    <!-- Links -->
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      {links.map((l) => (
        <a href={l.href} class={l.primary ? "pill-strong" : "pill"}>
          {l.label} →
        </a>
      ))}
    </div>

    <!-- Hero figure -->
    <figure class="mx-auto mt-12 max-w-5xl">
      <img
        src={`${import.meta.env.BASE_URL}/concept-diagram.png`}
        alt="Conceptual overview: 3 base models × 4 training corpora → 12 models → 16 table benchmarks + 4 RQs"
        class="rounded-lg border border-stone-200 bg-white p-2 shadow-sm"
      />
      <figcaption class="mt-3 text-center text-sm italic text-stone-500">
        We replicate four table LLMs by instruction-tuning three foundation models
        on four existing training datasets, yielding 12 models, then evaluate
        across 16 table benchmarks against four research questions.
      </figcaption>
    </figure>

    <!-- Abstract -->
    <section class="prose-paper mx-auto mt-16 max-w-3xl">
      <h2 class="text-2xl font-bold text-stone-900">📝 Abstract</h2>
      <p class="mt-4 leading-relaxed text-stone-700">
        Table understanding has evolved over decades of NLP research. In this work, we revisit this
        trajectory and highlight emerging challenges in the LLM era — particularly the
        <em>paradox of choice</em>: the difficulty of attributing performance gains amid diverse
        base models and training sets in the context of table instruction tuning.
      </p>
      <p class="mt-4 leading-relaxed text-stone-700">
        We replicate four table LLMs by instruction-tuning three foundation models on four
        existing datasets, yielding 12 models. We then evaluate these models across 16 table
        benchmarks. Our study is the first to quantitatively disentangle the effects of training
        data and base model selection, revealing that
        <strong class="font-semibold text-stone-900">base model choice plays a more dominant role than the training data itself</strong>.
        Generalization and reasoning remain challenging, inviting future effort on table modeling.
      </p>
    </section>

    <!-- TL;DR card -->
    <section class="prose-paper mx-auto mt-16 max-w-3xl">
      <h2 class="text-2xl font-bold text-stone-900">⚡ TL;DR</h2>
      <ul class="mt-4 space-y-2 text-stone-700">
        <li class="flex gap-3"><span class="text-amber-600">▸</span><span>Replicated <strong>4</strong> existing table LLMs (TableLlama, TableLLM, TableBenchLLM, TableGPT) on <strong>3</strong> 7B base models (Mistral-v0.3, OLMo, Phi-3) → 12 models.</span></li>
        <li class="flex gap-3"><span class="text-amber-600">▸</span><span>Evaluated all 12 across <strong>16</strong> table benchmarks + 5 general-capability benchmarks.</span></li>
        <li class="flex gap-3"><span class="text-amber-600">▸</span><span>Used Shapley R² decomposition to quantify the relative contributions of base model vs. training data.</span></li>
        <li class="flex gap-3"><span class="text-amber-600">▸</span><span>Finding: <strong>base model choice dominates</strong>; the training-corpus effect is smaller than commonly assumed.</span></li>
      </ul>
    </section>

    <!-- Interactive results browser -->
    <section class="mx-auto mt-16 max-w-6xl">
      <h2 class="text-2xl font-bold text-stone-900">📊 Results browser</h2>
      <p class="mt-3 leading-relaxed text-stone-700">
        Per-{`{base, training corpus, benchmark}`} metric. Toggle the
        chips to focus on a subset of base models, training corpora, or benchmarks.
        Cells are colour-scaled within each column (darker = higher).
      </p>

      <div class="mt-6 rounded-lg border border-stone-200 bg-white p-4 shadow-sm">
        <!-- Filter chips -->
        <div class="space-y-3">
          <div class="flex items-center gap-3">
            <span class="w-28 text-xs font-semibold uppercase tracking-wide text-stone-500">Base model</span>
            <div class="flex flex-wrap gap-1.5" data-filter-group="base">
              {baseOrder.map((b) => (
                <button class="filter-chip" data-value={b}>{baseDisplay[b]}</button>
              ))}
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span class="w-28 text-xs font-semibold uppercase tracking-wide text-stone-500">Train corpus</span>
            <div class="flex flex-wrap gap-1.5" data-filter-group="train">
              {trainOrder.map((t) => (
                <button class="filter-chip" data-value={t}>{trainDisplay[t]}</button>
              ))}
            </div>
          </div>
        </div>

        <div class="mt-4 overflow-x-auto">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr class="border-b border-stone-300 text-left text-xs uppercase tracking-wide text-stone-500">
                <th class="sticky left-0 z-10 bg-white py-2 pr-4 align-bottom">Model</th>
                {benchmarkOrder.map((b) => (
                  <th class="py-2 px-2 text-center align-bottom font-medium" data-bench={b}>
                    <span class="block max-w-[5.5rem] -rotate-0 break-words text-[11px] leading-tight text-stone-600">
                      {b.replace(/_test$/, "").replace(/^tablellm_/, "TLLM·")}
                    </span>
                  </th>
                ))}
              </tr>
            </thead>
            <tbody id="results-tbody">
              {combos.map(({ base, train, model }) => (
                <tr class="border-b border-stone-100 hover:bg-amber-50/40" data-base={base} data-train={train}>
                  <td class="sticky left-0 z-10 whitespace-nowrap bg-white py-1.5 pr-4 font-mono text-xs text-stone-700">
                    {model}
                  </td>
                  {benchmarkOrder.map((b) => {
                    const c = cells.get(`${model}|${b}`);
                    if (!c) return <td class="px-1 py-1.5 text-center text-stone-300" data-bench={b}>—</td>;
                    return (
                      <td class="px-1 py-1.5 text-center text-xs tabular-nums" data-bench={b} data-value={c.value}>
                        {c.value.toFixed(1)}
                      </td>
                    );
                  })}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="mt-3 text-xs text-stone-500">
          {results.length.toLocaleString()} cells loaded. Metric per
          benchmark is BLEU-4 for FeTaQA / ToTTo / TableLLM-FeTaQA, ROUGE-L
          for the rest. See the paper for details.
        </p>
      </div>
    </section>

    <style>
      .filter-chip {
        @apply rounded-full border border-stone-300 bg-white px-2.5 py-0.5 text-xs text-stone-600 transition;
      }
      .filter-chip.is-on {
        @apply border-amber-700 bg-amber-700 text-white;
      }
    </style>

    <script>
      // Filter UI: clicking a chip toggles whether that base/train value is
      // visible. By default every chip is "on". Cells are colour-scaled
      // per-benchmark on the visible rows.
      document.addEventListener("DOMContentLoaded", () => {
        const groups = document.querySelectorAll<HTMLDivElement>("[data-filter-group]");
        groups.forEach((g) => {
          g.querySelectorAll<HTMLButtonElement>("button.filter-chip").forEach((b) => {
            b.classList.add("is-on");
            b.addEventListener("click", () => {
              b.classList.toggle("is-on");
              applyFilters();
            });
          });
        });

        function applyFilters() {
          const onBase = new Set<string>();
          const onTrain = new Set<string>();
          document.querySelectorAll<HTMLButtonElement>("[data-filter-group='base'] .is-on").forEach((b) => onBase.add(b.dataset.value!));
          document.querySelectorAll<HTMLButtonElement>("[data-filter-group='train'] .is-on").forEach((b) => onTrain.add(b.dataset.value!));
          const rows = document.querySelectorAll<HTMLTableRowElement>("#results-tbody tr");
          rows.forEach((r) => {
            const visible = onBase.has(r.dataset.base!) && onTrain.has(r.dataset.train!);
            r.style.display = visible ? "" : "none";
          });
          colorScale();
        }

        function colorScale() {
          const headers = document.querySelectorAll<HTMLTableCellElement>("thead th[data-bench]");
          headers.forEach((h) => {
            const bench = h.dataset.bench!;
            const cells = Array.from(
              document.querySelectorAll<HTMLTableCellElement>(`tbody tr:not([style*='display: none']) td[data-bench='${bench}'][data-value]`)
            );
            const values = cells.map((c) => parseFloat(c.dataset.value!));
            const min = Math.min(...values);
            const max = Math.max(...values);
            cells.forEach((c) => {
              const v = parseFloat(c.dataset.value!);
              const t = max === min ? 0.5 : (v - min) / (max - min);
              const alpha = 0.05 + 0.55 * t;
              c.style.backgroundColor = `rgba(180, 83, 9, ${alpha.toFixed(3)})`;
              c.style.color = t > 0.55 ? "rgb(28, 25, 23)" : "rgb(68, 64, 60)";
            });
          });
        }

        applyFilters();
      });
    </script>

    <!-- Result figure -->
    <section class="mx-auto mt-16 max-w-3xl">
      <h2 class="text-2xl font-bold text-stone-900">🎯 Result: base model dominates</h2>
      <p class="mt-3 leading-relaxed text-stone-700">
        Shapley R² decomposition over the 3×4 grid: across the 16 table benchmarks,
        choice of base model contributes substantially more variance than the
        choice of training corpus.
      </p>
      <figure class="mt-6">
        <img
          src={`${import.meta.env.BASE_URL}/shapley.png`}
          alt="Shapley R² decomposition showing base model > training data contribution"
          class="rounded-lg border border-stone-200 bg-white p-3 shadow-sm"
        />
      </figure>
    </section>

    <!-- Citation -->
    <section class="mx-auto mt-16 max-w-3xl">
      <h2 class="text-2xl font-bold text-stone-900">📚 Citation</h2>
      <pre class="mt-4 overflow-x-auto rounded-lg border border-stone-200 bg-white p-4 text-sm font-mono leading-relaxed text-stone-800"><code>{bibtex}</code></pre>
    </section>
  </main>
</Layout>
