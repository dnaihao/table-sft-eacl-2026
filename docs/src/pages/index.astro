---
import Layout from "~/layouts/Layout.astro";

const title = "What Really Matters for Table LLMs?";
const subtitle = "A Meta-Evaluation of Model and Data Effects";
const venue = "Findings of EACL 2026";

const authors = [
  { name: "Naihao Deng", aff: "1", email: "dnaihao@umich.edu", note: "*" },
  { name: "Sheng Zhang", aff: "2" },
  { name: "Henghui Zhu", aff: "3" },
  { name: "Shuaichen Chang", aff: "2" },
  { name: "Jiani Zhang", aff: "5" },
  { name: "Alexander Hanbo Li", aff: "4" },
  { name: "Chung-Wei Hang", aff: "2" },
  { name: "Hideo Kobayashi", aff: "2" },
  { name: "Yiqun Hu", aff: "2" },
  { name: "Patrick Ng", aff: "2" },
];

const affs: Record<string, string> = {
  "1": "University of Michigan",
  "2": "AWS AI Labs",
  "3": "Figma",
  "4": "OKX",
  "5": "Google",
};

const links = [
  { label: "Paper (Anthology)", href: "https://aclanthology.org/2026.findings-eacl.195/", primary: true },
  { label: "Code (GitHub)", href: "https://github.com/dnaihao/table-sft-eacl-2026" },
  { label: "Models (HF)", href: "https://huggingface.co/collections/dnaihao/table-llms" },
  { label: "Predictions dataset", href: "https://huggingface.co/datasets/dnaihao/table-sft-eval-predictions" },
];

const bibtex = `@inproceedings{deng-etal-2026-really,
    title = "What Really Matters for Table {LLM}s? A Meta-Evaluation of Model and Data Effects",
    author = "Deng, Naihao  and Zhang, Sheng  and Zhu, Henghui  and Chang, Shuaichen  and Zhang, Jiani  and Li, Alexander Hanbo  and Hang, Chung-Wei  and Kobayashi, Hideo  and Hu, Yiqun  and Ng, Patrick",
    booktitle = "Findings of the Association for Computational Linguistics: EACL 2026",
    year = "2026",
    publisher = "Association for Computational Linguistics",
    url = "https://aclanthology.org/2026.findings-eacl.195/",
    doi = "10.18653/v1/2026.findings-eacl.195"
}`;
---

<Layout title={`${title} — ${venue}`}>
  <main class="mx-auto max-w-4xl px-6 py-16">
    <!-- Venue badge -->
    <div class="mb-6 flex justify-center">
      <span class="rounded-full bg-amber-100 px-4 py-1 text-sm font-medium uppercase tracking-wider text-amber-900">
        {venue}
      </span>
    </div>

    <!-- Title -->
    <h1 class="text-center text-4xl font-bold leading-tight text-stone-900 md:text-5xl">
      {title}
    </h1>
    <p class="mt-3 text-center text-xl text-stone-600 md:text-2xl">{subtitle}</p>

    <!-- Authors -->
    <div class="mx-auto mt-8 max-w-3xl text-center text-stone-700">
      <p class="leading-relaxed">
        {authors.map((a, i) => (
          <span>
            {a.name}
            <sup class="ml-0.5 text-xs text-stone-500">{a.aff}{a.note ?? ""}</sup>
            {i < authors.length - 1 ? <span>, </span> : null}
          </span>
        ))}
      </p>
      <p class="mt-2 text-sm text-stone-500">
        {Object.entries(affs).map(([k, v], i, arr) => (
          <span><sup class="text-xs">{k}</sup>{v}{i < arr.length - 1 ? <span> &nbsp;·&nbsp; </span> : null}</span>
        ))}
      </p>
      <p class="mt-1 text-xs text-stone-400">* Work done during Naihao's internship at AWS</p>
    </div>

    <!-- Links -->
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      {links.map((l) => (
        <a href={l.href} class={l.primary ? "pill-strong" : "pill"}>
          {l.label} →
        </a>
      ))}
    </div>

    <!-- Hero figure -->
    <figure class="mx-auto mt-12 max-w-5xl">
      <img
        src={`${import.meta.env.BASE_URL}/concept-diagram.png`}
        alt="Conceptual overview: 3 base models × 4 training corpora → 12 models → 16 table benchmarks + 4 RQs"
        class="rounded-lg border border-stone-200 bg-white p-2 shadow-sm"
      />
      <figcaption class="mt-3 text-center text-sm italic text-stone-500">
        We replicate four table LLMs by instruction-tuning three foundation models
        on four existing training datasets, yielding 12 models, then evaluate
        across 16 table benchmarks against four research questions.
      </figcaption>
    </figure>

    <!-- Abstract -->
    <section class="prose-paper mx-auto mt-16 max-w-3xl">
      <h2 class="text-2xl font-bold text-stone-900">Abstract</h2>
      <p class="mt-4 leading-relaxed text-stone-700">
        Table understanding has evolved over decades of NLP research. In this work, we revisit this
        trajectory and highlight emerging challenges in the LLM era — particularly the
        <em>paradox of choice</em>: the difficulty of attributing performance gains amid diverse
        base models and training sets in the context of table instruction tuning.
      </p>
      <p class="mt-4 leading-relaxed text-stone-700">
        We replicate four table LLMs by instruction-tuning three foundation models on four
        existing datasets, yielding 12 models. We then evaluate these models across 16 table
        benchmarks. Our study is the first to quantitatively disentangle the effects of training
        data and base model selection, revealing that
        <strong class="font-semibold text-stone-900">base model choice plays a more dominant role than the training data itself</strong>.
        Generalization and reasoning remain challenging, inviting future effort on table modeling.
      </p>
    </section>

    <!-- TL;DR card -->
    <section class="prose-paper mx-auto mt-16 max-w-3xl">
      <h2 class="text-2xl font-bold text-stone-900">TL;DR</h2>
      <ul class="mt-4 space-y-2 text-stone-700">
        <li class="flex gap-3"><span class="text-amber-600">▸</span><span>Replicated <strong>4</strong> existing table LLMs (TableLlama, TableLLM, TableBenchLLM, TableGPT) on <strong>3</strong> 7B base models (Mistral-v0.3, OLMo, Phi-3) → 12 models.</span></li>
        <li class="flex gap-3"><span class="text-amber-600">▸</span><span>Evaluated all 12 across <strong>16</strong> table benchmarks + 5 general-capability benchmarks.</span></li>
        <li class="flex gap-3"><span class="text-amber-600">▸</span><span>Used Shapley R² decomposition to quantify the relative contributions of base model vs. training data.</span></li>
        <li class="flex gap-3"><span class="text-amber-600">▸</span><span>Finding: <strong>base model choice dominates</strong>; the training-corpus effect is smaller than commonly assumed.</span></li>
      </ul>
    </section>

    <!-- Headline result figure -->
    <section class="mx-auto mt-16 max-w-3xl">
      <h2 class="text-2xl font-bold text-stone-900">Headline result: base model dominates</h2>
      <p class="mt-3 leading-relaxed text-stone-700">
        Shapley R² decomposition over the 3×4 grid: across the 16 table benchmarks,
        choice of base model contributes substantially more variance than the
        choice of training corpus.
      </p>
      <figure class="mt-6">
        <img
          src={`${import.meta.env.BASE_URL}/shapley.png`}
          alt="Shapley R² decomposition showing base model > training data contribution"
          class="rounded-lg border border-stone-200 bg-white p-3 shadow-sm"
        />
      </figure>
    </section>

    <!-- Citation -->
    <section class="mx-auto mt-16 max-w-3xl">
      <h2 class="text-2xl font-bold text-stone-900">Citation</h2>
      <pre class="mt-4 overflow-x-auto rounded-lg border border-stone-200 bg-white p-4 text-sm font-mono leading-relaxed text-stone-800"><code>{bibtex}</code></pre>
    </section>
  </main>
</Layout>
